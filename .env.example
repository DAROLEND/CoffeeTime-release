APP_ENV=development
APP_URL=http://localhost

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# ── Telegram notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LiqPay payment gateway ────────────────────────────────────────────────────
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=1

# ── Email (PHPMailer / Gmail SMTP) ────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Coffee Time

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_LIFETIME=3600

# ── Google Places API (optional) ─────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_PLACE_ID=
